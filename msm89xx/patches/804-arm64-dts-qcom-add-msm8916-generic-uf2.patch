--- /dev/null
+++ b/arch/arm64/boot/dts/qcom/msm8916-generic-uf02.dts
@@ -0,0 +1,77 @@
+// SPDX-License-Identifier: GPL-2.0-only
+
+/dts-v1/;
+
+#include "msm8916-ufi.dtsi"
+
+#include <dt-bindings/gpio/gpio.h>
+#include <dt-bindings/leds/common.h>
+
+/ {
+	model = "UF02 4G Modem Stick";
+	compatible = "uf02,250605v0s", "qcom,msm8916";
+};
+
+&button_restart {
+	gpios = <&tlmm 23 GPIO_ACTIVE_LOW>;
+};
+
+&led_r {
+	gpios = <&tlmm 72 GPIO_ACTIVE_HIGH>;
+};
+
+&led_g {
+	function = LED_FUNCTION_WAN;
+	gpios = <&tlmm 71 GPIO_ACTIVE_HIGH>;
+};
+
+&led_b {
+	function = LED_FUNCTION_WLAN;
+	gpios = <&tlmm 73 GPIO_ACTIVE_HIGH>;
+};
+
+&button_default {
+	pins = "gpio23";
+	bias-pull-up;
+};
+
+&gpio_leds_default {
+	pins = "gpio71", "gpio72", "gpio73";
+};
+
+&tlmm {
+	sim_hotplug_gpio: sim-hotplug-gpio {
+		gpio-hog;
+		gpios = <114 GPIO_ACTIVE_HIGH>;
+		input;
+		line-name = "sim_hotplug";
+	};
+
+	esim1_en_gpio: esim1-en-gpio {
+		gpio-hog;
+		gpios = <119 GPIO_ACTIVE_HIGH>;
+		output-high;
+		line-name = "esim1_en";
+	};
+
+	esim2_en_gpio: esim2-en-gpio {
+		gpio-hog;
+		gpios = <14 GPIO_ACTIVE_HIGH>;
+		output-low;
+		line-name = "esim2_en";
+	};
+
+	esim3_en_gpio: esim3-en-gpio {
+		gpio-hog;
+		gpios = <12 GPIO_ACTIVE_HIGH>;
+		output-low;
+		line-name = "esim3_en";
+	};
+
+	modem_en_gpio: modem-en-gpio {
+		gpio-hog;
+		gpios = <68 GPIO_ACTIVE_HIGH>;
+		output-high;
+		line-name = "modem_en";
+	};
+};
